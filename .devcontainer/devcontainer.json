{
  // Spyglass Workshop — MySQL fallback via GitHub Codespaces.
  //
  // If the LAN MySQL instance is unavailable, attendees open this repo in a
  // Codespace and connect their notebooks to localhost:3306 instead of the
  // instructor's IP.  See database/README.md → "Codespaces Fallback".
  //
  // Credentials (same as the LAN instance):
  //   User: sailor   Password: galley    (attendee)
  //   User: captain  Password: bridge    (admin)
  //   User: swab     Password: bilge     (read-only)
  //   Root password: tutorial

  "name": "Spyglass Workshop DB",
  // MySQL is installed directly in the Dockerfile (apt) instead of via the
  // ghcr.io/devcontainers/features/mysql Feature, which fails to resolve in
  // some Codespace environments (error 1302 / permission denied on GHCR).
  "build": { "dockerfile": "Dockerfile" },

  // Start MySQL, set root password, write workshop config, create users.
  "postCreateCommand": "sudo service mysql start && sudo mysql -e \"ALTER USER 'root'@'localhost' IDENTIFIED WITH mysql_native_password BY 'tutorial'; FLUSH PRIVILEGES;\" && bash .devcontainer/setup-db.sh",

  "forwardPorts": [3306],
  "portsAttributes": {
    "3306": {
      "label": "MySQL Workshop DB",
      "onAutoForward": "silent"
    }
  },

  "remoteUser": "vscode"
}
